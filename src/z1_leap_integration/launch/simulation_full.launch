<launch>
    <!--
      Full gesture-to-arm simulation pipeline
    -->

    <!-- ============ Arguments ============ -->
    <arg name="show_viz"    default="true"
         doc="Show CV2 hand skeleton overlay window" />
    <arg name="pipeline"    default="ompl" />
    <arg name="use_gazebo"  default="true"
         doc="Use Gazebo physics simulation instead of MoveIt fake controllers" />
    <arg name="rviz"        default="false"
         doc="Show RViz visualization (applies to both modes)" />

    <!-- ============ 1a. Lightweight: MoveIt fake controllers + RViz ============ -->
    <include file="$(find z1_moveit_config)/launch/demo.launch"
             unless="$(arg use_gazebo)">
        <arg name="pipeline" value="$(arg pipeline)" />
        <arg name="use_rviz" value="$(arg rviz)" />
    </include>

    <!-- ============ 1b. Gazebo: full physics sim + MoveIt ============ -->
    <include file="$(find z1_bringup)/launch/sim_arm.launch"
             if="$(arg use_gazebo)">
        <arg name="rviz"             value="$(arg rviz)" />
        <arg name="UnitreeGripperYN" value="false" />
    </include>

    <!-- ============ 2. Config params ============ -->
    <rosparam file="$(find z1_leap_integration)/config/gesture_config.yaml"
              command="load" />

    <!-- Gazebo sim-time runs slower than wall-clock, so MoveIt's default
         trajectory timeout (1.2× planned duration) fires prematurely.
         These params MUST be under the move_group/ namespace because
         trajectory_execution.launch.xml is included with ns="move_group". -->
    <param name="move_group/trajectory_execution/execution_duration_monitoring" value="false" />
    <param name="move_group/trajectory_execution/allowed_execution_duration_scaling" value="4.0" />
    <!-- After an aborted trajectory the arm is still settling — allow
         up to 0.05 rad mismatch before rejecting the next plan's start. -->
    <param name="move_group/trajectory_execution/allowed_start_tolerance" value="0.05" />

    <!-- ============ 3. Gesture Detector ============ -->
    <!--
      This script uses the gesture-env conda Python (shebang).
      roslaunch inherits PYTHONPATH so rospy is importable.
    -->
    <node pkg="z1_leap_integration"
          type="detect_point.py"
          name="detect_point"
          output="screen">
        <param name="show_visualization" value="$(arg show_viz)" />
    </node>

    <!-- ============ 4. Look-at-Point Controller ============ -->
    <!--
      Subscribes to /leap/pointing_target published by detect_point.
      Uses MoveIt to orient the arm so link06 +X points at the target.
    -->
    <node pkg="z1_leap_integration"
          type="look_at_point.py"
          name="look_at_point"
          output="screen" />

</launch>
