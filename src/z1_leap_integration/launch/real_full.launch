<launch>
    <!--
      Full gesture-to-arm pipeline for the REAL Z1 hardware.
    -->

    <!-- ============ Arguments ============ -->
    <arg name="show_viz"         default="true"
         doc="Show CV2 hand skeleton overlay window" />
    <arg name="UnitreeGripperYN" default="false"
         doc="Attach Unitree gripper (false = bare arm, no gripper)" />
    <arg name="rviz"             default="false"
         doc="Show RViz visualization" />

    <!-- ============ 1. Real Z1 arm (controller + HW + MoveIt) ============ -->
    <include file="$(find z1_bringup)/launch/real_arm.launch">
        <arg name="UnitreeGripperYN" value="$(arg UnitreeGripperYN)" />
        <arg name="rviz"             value="$(arg rviz)" />
    </include>

    <!-- ============ 2. Config params ============ -->
    <rosparam file="$(find z1_leap_integration)/config/gesture_config.yaml"
              command="load" />

    <!-- Give the real arm generous execution time -->
    <param name="move_group/trajectory_execution/execution_duration_monitoring" value="false" />
    <param name="move_group/trajectory_execution/allowed_execution_duration_scaling" value="4.0" />
    <param name="move_group/trajectory_execution/allowed_start_tolerance" value="0.05" />

    <!-- ============ 3. Gesture Detector (LeapC + Leap Motion) ============ -->
    <node pkg="z1_leap_integration"
          type="detect_point.py"
          name="detect_point"
          output="screen">
        <param name="show_visualization" value="$(arg show_viz)" />
    </node>

    <!-- ============ 4. Look-at-Point Controller ============ -->
    <node pkg="z1_leap_integration"
          type="look_at_point.py"
          name="look_at_point"
          output="screen" />

</launch>
